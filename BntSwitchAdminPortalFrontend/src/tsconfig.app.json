{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "outDir": "../out-tsc/app",
    "types": [
      "underscore"
    ]
  },
  "exclude": [
    "src/test.ts",
    "**/*.spec.ts"
    ],
    "files": [
        "main.ts",
        "polyfills.ts"
    ],
    "include": [
        "src/**/*.d.ts"
    ],
    "angularCompilerOptions": {
        "enableIvy": true,
    }
}
