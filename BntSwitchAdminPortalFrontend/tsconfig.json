
{
    "compileOnSave": false,
    "compilerOptions": {
        "baseUrl": "./",
        "skipLibCheck": true,
        "downlevelIteration": true,
        "outDir": "./dist/out-tsc",
        "importHelpers": true,
        "sourceMap": true,
        "declaration": false,
        "moduleResolution": "node",
        "module": "es2020",
        "experimentalDecorators": true,
        "target": "es2020",
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "typeRoots": [
            "node_modules/@types"
        ],
        "lib": [
            "es2018",
            "dom"
        ],
        "paths": {
            "bnt": [
                "library/bnt/src"
            ],
            "@app/*": [
                "src/app/*"
            ],
            "@env/*": [
                "src/environments/*"
            ]
        }
    }
}
