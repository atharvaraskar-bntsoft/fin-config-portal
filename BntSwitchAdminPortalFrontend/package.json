{
  "name": "adminportal",
  "version": "1.0.0",
  "scripts": {
    "ng": "node_modules/@angular/cli/bin/ng",
    "prettier": "node_modules/.bin/prettier --write \"**/*.{js,json,css,scss,less,md,ts,html,component.html}\"",
    "start": "npm run lint",
    "build": "npm install --save-dev @types/node@18.11.9  --legacy-peer-deps && node --max_old_space_size=8192 node_modules/@angular/cli/bin/ng build --base-href /bntmvpadm/app/ --configuration production",
    "libCopyFiles": "cp README.md LICENSE dist/bnt",
    "build:lib": "node_modules/@angular/cli/bin/ng build bnt --configuration production && npm run libCopyFiles",
    "publish:lib": "npm publish dist/bnt",
    "build:demo": "node_modules/@angular/cli/bin/ng build adminportal --configuration production --base-href=/bnt/",
    "gh-pages": "node ./scripts/gh-pages-multi/bin/gh-pages-multi.js deploy -s dist/adminportal --dry-run --tmp-dir",
    "test": "node_modules/@angular/cli/bin/ng test --watch=false --code-coverage",
    "sonar": "sonar-scanner",
    "test:demo": "node_modules/@angular/cli/bin/ng test adminportal",
    "test:lib": "node_modules/@angular/cli/bin/ng test bnt",
    "lint": "node --max_old_space_size=8192 node_modules/@angular/cli/bin/ng lint",
    "lint:fix": "node --max_old_space_size=8192 node_modules/@angular/cli/bin/ng lint adminportal --fix",
    "lint:ci": "npm run lint",
    "e2e": "node_modules/@angular/cli/bin/ng e2e",
    "server": "node server.js",
    "postinstall": "ngcc",
    "format:fix": "node_modules/.bin/pretty-quick --staged",
    "format:prettier": "node_modules/.bin/prettier --write \"**/*.*(js|jsx|ts|tsx|html)\"",
    "format:check": "node_modules/.bin/prettier --config ./.prettierrc --list-different \"src/{app,environments,assets, node_modules}/**/*{.ts,.js,.json,.css,.scss,.html}\""
  },
  "private": true,
